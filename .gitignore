build/
release/
.sourceknight
.venv

# Generated by .github/workflows/release.yml; runtime falls back to `git describe`
/web/configs/version.json

# Astro + Starlight build artifacts (docs/ — see #1333). The auto-captured
# screenshots under docs/src/assets/auto/ ARE committed (the screenshot
# diff lands in the same PR as the UI change), so they're NOT listed here.
docs/node_modules/
docs/dist/
docs/.astro/
